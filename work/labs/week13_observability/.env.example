# OpenAI API 設定 (必須)
OPENAI_API_KEY=your_openai_api_key_here

# Tavily 搜尋工具設定 (必須)
TAVILY_API_KEY=your_tavily_api_key_here

# Opik 雲端部署配置 (推薦)
# 從 https://www.comet.com/api/my/settings/ 獲取 API 密鑰
OPIK_API_KEY=your_opik_api_key_here
OPIK_WORKSPACE=crewai-observability
OPIK_PROJECT_NAME=week13-observability

# Opik 本地部署選項
# 設為 true 使用本地 Opik 實例 (需要先啟動 Docker 容器)
# 設為 false 使用 Comet.com 雲端版本
OPIK_LOCAL=false

# 其他可選配置
# 啟用/停用追蹤功能
ENABLE_TRACKING=true

# 日誌級別
LOG_LEVEL=INFO